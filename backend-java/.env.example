# AI Study Hub Java backend environment template
# Copy this file to .env and fill in your actual credentials.
# Do not commit the .env file with secrets to Git.

# Database
DB_HOST=localhost
DB_INSTANCE=
DB_NAME=AI_StudyHub
DB_USERNAME=sa
DB_PASSWORD=your_db_password
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=AI_StudyHub;encrypt=false;trustServerCertificate=true

# JWT
# Generate a random secret with at least 32 characters in production.
JWT_SECRET=your_jwt_secret_key_at_least_32_characters
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_MS=604800000

# Email
# SMTP settings for notification emails (verify-email, forgot-password, etc.)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# Python AI service
# Base URL of the python service handling LLM/AI features.
PYTHON_AI_BASE_URL=http://127.0.0.1:8000
PYTHON_INTERNAL_API_KEY=your_internal_python_api_key

# Supabase
# Required if STORAGE_PROVIDER=SUPABASE
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_role_key
SUPABASE_SECRET_KEY=your_supabase_service_role_key
SUPABASE_BUCKET=documents

# Frontend URLs
FRONTEND_URL=http://localhost:5173
EMAIL_VERIFY_URL=http://localhost:5173/verify-email
PASSWORD_RESET_URL=http://localhost:5173/reset-password
APP_FRONTEND_URL=http://localhost:5173

# PayOS
# PayOS payment gateway credentials
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# AI provider config encryption key
# Master key used to encrypt API keys stored in the database. Must be at least 32 characters.
AI_CONFIG_MASTER_KEY=your_ai_config_master_key_at_least_32_characters
AI_CONFIG_LEGACY_MASTER_KEY=

# Document storage selection (SUPABASE or CLOUDFLARE_R2)
STORAGE_PROVIDER=SUPABASE

# Cloudflare R2 Configuration
# Required if STORAGE_PROVIDER=CLOUDFLARE_R2
CLOUDFLARE_R2_ACCOUNT_ID=your_r2_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET=ai-studyhub
CLOUDFLARE_R2_PUBLIC_URL=
