# AI Study Hub Python AI service environment template
# Copy this file to .env and fill in your actual credentials.
# Do not commit the .env file with secrets to Git.

# Provider selection
# Options: gemini, openai, deepseek
LLM_PROVIDER=gemini

# Gemini API Configuration
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key

# OpenAI API Configuration
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your_openai_api_key

# DeepSeek API Configuration
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=your_deepseek_api_key

# Internal API protection
# Optional locally, recommended before deploy.
# If set, every endpoint except /health requires header:
# X-Internal-API-Key: <same value>
# This must match PYTHON_INTERNAL_API_KEY in backend-java/.env.
PYTHON_INTERNAL_API_KEY=

# CORS
# Comma-separated allowed browser origins.
PYTHON_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
